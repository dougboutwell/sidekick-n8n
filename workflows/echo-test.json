{
  "name": "Echo Test",
  "description": "Simple webhook echo for testing the Claude Code to n8n MCP pipeline.",
  "nodes": [
    {
      "name": "Echo Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [240, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "echo",
        "responseMode": "lastNode",
        "responseData": "firstEntryJson"
      }
    },
    {
      "name": "Echo Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [540, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "return [{ json: { echo: $input.all()[0].json.body.message || \"no message\" } }];"
      }
    }
  ],
  "connections": {
    "Echo Webhook": {
      "main": [[{ "node": "Echo Message", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
